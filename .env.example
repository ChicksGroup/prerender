################################################################################
# Prerender server — environment template
#
# Copy to `.env` and fill in. NOTE: the server does NOT auto-load .env (no
# dotenv dependency). Use these values one of these ways:
#   • local shell:   export $(grep -v '^#' .env | xargs)   (bash/zsh)
#   • Docker:        docker run --env-file .env ...
#   • DO App Platform: set them as app-level envs (.do/app.yaml or dashboard)
#
# Only a handful are required (marked [REQUIRED]). Everything else has a safe
# default and can stay commented out.
#
# ⚠ TRUTHINESS TRAP: vars marked [BOOL-ANY] are read as `process.env.X || false`,
#   so ANY non-empty value — INCLUDING the string "false" — turns them ON.
#   To keep them OFF, leave them commented/unset. Only uncomment to enable.
################################################################################


# ─── Network ──────────────────────────────────────────────────────────────────
# HTTP port the server listens on. Match your platform's http_port.
PORT=3000


# ─── Security (wired in server.js — lock down the public endpoint) ─────────────
# [REQUIRED] Shared secret the site middleware must send as `X-Prerender-Token`.
# Generate a long random value, e.g.  openssl rand -hex 32
# If unset, the tokenAuth plugin allows ALL requests (dev only).
PRERENDER_AUTH_TOKEN=

# [REQUIRED] Comma-separated base domains allowed to be rendered (whitelist).
# Matches the domain AND all of its subdomains: `chicksx.com` also allows
# www.chicksx.com, api.chicksx.com, etc. Lookalikes (evilchicksx.com,
# chicksx.com.attacker.com) are rejected. Hostnames only — no scheme/path.
ALLOWED_DOMAINS=chicksgold.com,chicksx.com


# ─── Render behavior / SEO parity ──────────────────────────────────────────────
# ⚠ DO NOT SET FollowRedirects. [BOOL-ANY] — even FOLLOW_REDIRECTS=false turns it
#   ON, which makes the server follow 301/302 instead of returning them to the
#   crawler (bad for SEO). Leave commented to keep the correct default (off).
# FOLLOW_REDIRECTS=

# ms to wait after the last network request before considering the page done
# (network-idle fallback when a page doesn't set window.prerenderReady).
WAIT_AFTER_LAST_REQUEST=500

# ms between page-done checks.
PAGE_DONE_CHECK_INTERVAL=500

# Max ms to wait for a page to load before returning whatever rendered so far.
PAGE_LOAD_TIMEOUT=20000

# ⚠ Leave UNSET for SEO parity: on timeout the server returns the partial HTML
#   as 200 (not an error code). Setting this to e.g. 504 would serve errors to
#   Google for slow pages = deindex risk.
# TIMEOUT_STATUS_CODE=

# HTTP status for true render errors (Chrome crash / parse failure).
RENDERING_ERROR_STATUS_CODE=504

# [BOOL-ANY] Parse + include Shadow DOM in the HTML output. Leave unset = off.
# PARSE_SHADOW_DOM=true


# ─── Resilience: concurrency + graceful shutdown ───────────────────────────────
# Max concurrent renders before shedding load with 429 + Retry-After.
# 0 = unlimited. Heuristic: floor((RAM_GB*1024 - 300) / 350). 2GB instance ≈ 4.
MAX_CONCURRENT_RENDERS=4

# Retry-After (seconds) sent with the 429 when at capacity.
OVERLOAD_RETRY_AFTER=2

# ms to wait for in-flight renders to drain on SIGTERM/SIGINT before exiting.
# Keep below the platform's shutdown grace window and the 60s in-flight cleanup.
SHUTDOWN_DRAIN_TIMEOUT_MS=20000


# ─── Chrome / container ────────────────────────────────────────────────────────
# Path to the Chrome/Chromium binary. The Dockerfile installs Chromium here.
# Leave unset to use the OS-default location (local dev with Chrome installed).
CHROME_LOCATION=/usr/bin/chromium

# Extra Chrome flags (space-separated), appended to the defaults. The three
# below are REQUIRED to run headless Chrome as non-root inside a container.
EXTRA_CHROME_FLAGS=--no-sandbox --disable-dev-shm-usage --disable-setuid-sandbox

# Chrome DevTools remote debugging port (rarely needs changing).
# BROWSER_DEBUGGING_PORT=9222


# ─── Browser restart (memory hygiene) ──────────────────────────────────────────
# Restart Chrome when idle and this many ms have passed since last restart.
BROWSER_TRY_RESTART_PERIOD=300000

# Force a Chrome restart after this many ms regardless of idle (browserForceRestart).
BROWSER_FORCE_RESTART_PERIOD=1800000


# ─── Logging / debug ───────────────────────────────────────────────────────────
# Per-request network logging. Checked as === 'true', so "false" is safe here.
PRERENDER_LOG_REQUESTS=false
# [BOOL-ANY] alternative request-logging flag — leave unset; PRERENDER_LOG_REQUESTS above is preferred.
# LOG_REQUESTS=true
# [BOOL-ANY] capture page console.log into pageLoadInfo. Leave unset = off.
# CAPTURE_CONSOLE_LOG=true
# [BOOL-ANY] allow service workers to load. Leave unset = off.
# ENABLE_SERVICE_WORKER=true
# Set to any value to enable verbose debug logging (util.debug).
# PRERENDER_DEBUG_LOG=1


# ─── Redis HTML cache (Phase 2) ─────────────────────────────────────────────────
# Master switch. Checked as === 'true'. Leave 'false' until the cache is rolled
# out; when off, the plugin is a complete no-op (pure live render).
CACHE_ENABLED=false

# Preferred: full connection string. Use rediss:// for TLS (DO Managed Valkey).
# REDIS_URL=rediss://default:PASSWORD@HOST:PORT
# --- OR discrete settings (used only when REDIS_URL is unset) ---
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# Key namespace. Bump only via the in-code v1 schema version, not this.
# CACHE_KEY_PREFIX=prerender
# gzip the stored HTML body. Checked as !== 'false' (default on); set false to disable.
# CACHE_COMPRESSION=true
# Which status codes are allowed into the cache (no eviction, so keep it tight).
# CACHE_CACHEABLE_STATUS=200,301,302,404
# Refuse to cache a 200 HTML body smaller than this many bytes — guards against
# permanently storing an empty/half-rendered shell (no eviction). 0 = off.
# CACHE_MIN_HTML_BYTES=20000

# Where HTML bodies are stored: 'redis' (default; bodies in Valkey RAM) or
# 'spaces' (bodies in DO Spaces / S3 — far cheaper for a large no-eviction
# corpus; the single-flight lock + refresh index stay in Redis either way).
# Switching invalidates the existing cache (keys differ) — plan to re-seed.
# CACHE_STORE=spaces
# DO Spaces (or S3) settings — required when CACHE_STORE=spaces:
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_REGION=us-east-1
# SPACES_BUCKET=chicks-prerender-cache
# SPACES_PREFIX=                          # optional key prefix, e.g. prod/
# SPACES_KEY=                             # Spaces access key (or AWS_ACCESS_KEY_ID)
# SPACES_SECRET=                          # Spaces secret  (or AWS_SECRET_ACCESS_KEY)
# SPACES_FORCE_PATH_STYLE=false


# ─── SaaS fallback + cache-clear (prerender.io) ─────────────────────────────────
# FALLBACK: when our own render can't be served (capacity 429 / 5xx / timeout),
# proxy the request to the SaaS prerender, return that to the crawler, AND cache
# it (so the next request is a local hit). Requires an active prerender.io plan.
# FALLBACK_ENABLED=true
# FALLBACK_TOKEN=                          # prerender.io API token
# FALLBACK_URL=https://service.prerender.io
# FALLBACK_STATUS_CODES=429,500,502,503,504
# FALLBACK_TIMEOUT_MS=25000
# FALLBACK_FORCE=true                      # TEST ONLY: route EVERY request to the
#                                          # fallback (skips local render) to verify it
# Tip: also set TIMEOUT_STATUS_CODE=504 so render timeouts trigger the fallback.

# CACHE-CLEAR: after WE render a page fresh, evict prerender.io's now-stale copy
# so a later fallback re-renders fresh. Best-effort + serialized — the SaaS API
# allows only ONE clear job per account at a time, so under big render bursts the
# bounded queue drops overflow (pair with an occasional domain-pattern clear for
# guaranteed bulk freshness). Token defaults to FALLBACK_TOKEN/PRERENDER_IO_TOKEN.
# SAAS_CLEAR_ENABLED=true
# SAAS_CLEAR_TOKEN=
# SAAS_CLEAR_API=https://api.prerender.io
# SAAS_CLEAR_STATUS=200,301,302,404
# SAAS_CLEAR_MAX_QUEUE=5000

# Single-flight (stops a thundering herd of identical renders across instances).
# SINGLEFLIGHT_ENABLED=true          # checked as !== 'false'
# SINGLEFLIGHT_LOCK_TTL_MS=30000     # lock auto-expiry (must exceed worst-case render)
# SINGLEFLIGHT_WAIT_MAX_MS=5000      # max a waiter polls before rendering through
# SINGLEFLIGHT_WAIT_POLL_MS=150      # waiter poll interval


# ─── Optional plugins (NOT wired in server.js by default) ──────────────────────
# basicAuth — only if you swap it in for tokenAuth:
# BASIC_AUTH_USERNAME=
# BASIC_AUTH_PASSWORD=
# blacklist — only if you wire prerender.blacklist():
# BLACKLISTED_DOMAINS=
