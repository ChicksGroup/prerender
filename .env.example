################################################################################
# Prerender server — environment template
#
# Copy to `.env` and fill in. NOTE: the server does NOT auto-load .env (no
# dotenv dependency). Use these values one of these ways:
#   • local shell:   export $(grep -v '^#' .env | xargs)   (bash/zsh)
#   • Docker:        docker run --env-file .env ...
#   • DO App Platform: set them as app-level envs (.do/app.yaml or dashboard)
#
# Only a handful are required (marked [REQUIRED]). Everything else has a safe
# default and can stay commented out.
#
# ⚠ TRUTHINESS TRAP: vars marked [BOOL-ANY] are read as `process.env.X || false`,
#   so ANY non-empty value — INCLUDING the string "false" — turns them ON.
#   To keep them OFF, leave them commented/unset. Only uncomment to enable.
################################################################################


# ─── Network ──────────────────────────────────────────────────────────────────
# HTTP port the server listens on. Match your platform's http_port.
PORT=3000


# ─── Security (wired in server.js — lock down the public endpoint) ─────────────
# [REQUIRED] Shared secret the site middleware must send as `X-Prerender-Token`.
# Generate a long random value, e.g.  openssl rand -hex 32
# If unset, the tokenAuth plugin allows ALL requests (dev only).
PRERENDER_AUTH_TOKEN=

# [REQUIRED] Comma-separated base domains allowed to be rendered (whitelist).
# Matches the domain AND all of its subdomains: `chicksx.com` also allows
# www.chicksx.com, api.chicksx.com, etc. Lookalikes (evilchicksx.com,
# chicksx.com.attacker.com) are rejected. Hostnames only — no scheme/path.
ALLOWED_DOMAINS=chicksgold.com,chicksx.com


# ─── Render behavior / SEO parity ──────────────────────────────────────────────
# ⚠ DO NOT SET FollowRedirects. [BOOL-ANY] — even FOLLOW_REDIRECTS=false turns it
#   ON, which makes the server follow 301/302 instead of returning them to the
#   crawler (bad for SEO). Leave commented to keep the correct default (off).
# FOLLOW_REDIRECTS=

# ms to wait after the last network request before considering the page done
# (network-idle fallback when a page doesn't set window.prerenderReady).
WAIT_AFTER_LAST_REQUEST=500

# ms between page-done checks.
PAGE_DONE_CHECK_INTERVAL=500

# Max ms to wait for a page to load before returning whatever rendered so far.
PAGE_LOAD_TIMEOUT=20000

# ⚠ Leave UNSET for SEO parity: on timeout the server returns the partial HTML
#   as 200 (not an error code). Setting this to e.g. 504 would serve errors to
#   Google for slow pages = deindex risk.
# TIMEOUT_STATUS_CODE=

# HTTP status for true render errors (Chrome crash / parse failure).
RENDERING_ERROR_STATUS_CODE=504

# [BOOL-ANY] Parse + include Shadow DOM in the HTML output. Leave unset = off.
# PARSE_SHADOW_DOM=true


# ─── Resilience: concurrency + graceful shutdown ───────────────────────────────
# Max concurrent renders before shedding load with 429 + Retry-After.
# 0 = unlimited. Heuristic: floor((RAM_GB*1024 - 300) / 350). 2GB instance ≈ 4.
MAX_CONCURRENT_RENDERS=4

# Retry-After (seconds) sent with the 429 when at capacity.
OVERLOAD_RETRY_AFTER=2

# ms to wait for in-flight renders to drain on SIGTERM/SIGINT before exiting.
# Keep below the platform's shutdown grace window and the 60s in-flight cleanup.
SHUTDOWN_DRAIN_TIMEOUT_MS=20000


# ─── Chrome / container ────────────────────────────────────────────────────────
# Path to the Chrome/Chromium binary. The Dockerfile installs Chromium here.
# Leave unset to use the OS-default location (local dev with Chrome installed).
CHROME_LOCATION=/usr/bin/chromium

# Extra Chrome flags (space-separated), appended to the defaults. The three
# below are REQUIRED to run headless Chrome as non-root inside a container.
# Chrome's background-networking/telemetry flags (--disable-background-networking,
# --disable-component-update, etc.) are now baked into the default flags in
# lib/browsers/chrome.js, so you do NOT need to add them here.
# When routing renders through the ssl-bump caching proxy (PROXY_SERVER), also
# append --ignore-certificate-errors so Chrome accepts the proxy's bump certs.
EXTRA_CHROME_FLAGS=--no-sandbox --disable-dev-shm-usage --disable-setuid-sandbox

# Chrome DevTools remote debugging port (rarely needs changing).
# BROWSER_DEBUGGING_PORT=9222

# Optional forward proxy for Chrome's outbound subresource fetches (becomes
# Chrome's --proxy-server flag). Point it at a caching proxy (e.g. Squid with
# ssl-bump) so the SPA's immutable, content-hashed JS/CSS bundles are served
# from cache across renders instead of re-fetched from the CDN on every render
# (each render uses a fresh, cold Chrome context). Cuts CDN/Argo egress.
# Chrome already overrides TLS cert errors, so an intercepting proxy's cert is
# accepted without distributing a CA. Leave unset to fetch directly.
# PROXY_SERVER=http://127.0.0.1:3128


# ─── Browser restart (memory hygiene) ──────────────────────────────────────────
# Restart Chrome when idle and this many ms have passed since last restart.
BROWSER_TRY_RESTART_PERIOD=300000

# Force a Chrome restart after this many ms regardless of idle (browserForceRestart).
BROWSER_FORCE_RESTART_PERIOD=1800000

# Stall watchdog. If renders are in flight but no Chrome tab has opened
# successfully for this many ms, force a restart REGARDLESS of in-flight count —
# the only path that breaks the force-restart 504 deadlock / ECONNRESET wedge
# under continuous (refresher) load, where the idle-only recycle above never
# fires. 0 disables it. A non-numeric value falls back to the default (logged),
# never silently off — set an integer.
BROWSER_WATCHDOG_STALL_MS=90000
# How often (ms) the watchdog evaluates.
BROWSER_WATCHDOG_PERIOD=15000
# If the watchdog has to restart Chrome this many times within ~10 min without it
# staying healthy, the host is likely poisoned (OOM, port exhaustion) — exit so
# the platform replaces the box instead of thrashing one. 0 disables escalation.
BROWSER_WATCHDOG_MAX_RESTARTS=5


# ─── Logging / debug ───────────────────────────────────────────────────────────
# Per-request network logging. Checked as === 'true', so "false" is safe here.
PRERENDER_LOG_REQUESTS=false
# [BOOL-ANY] alternative request-logging flag — leave unset; PRERENDER_LOG_REQUESTS above is preferred.
# LOG_REQUESTS=true
# [BOOL-ANY] capture page console.log into pageLoadInfo. Leave unset = off.
# CAPTURE_CONSOLE_LOG=true
# [BOOL-ANY] allow service workers to load. Leave unset = off.
# ENABLE_SERVICE_WORKER=true
# Set to any value to enable verbose debug logging (util.debug).
# PRERENDER_DEBUG_LOG=1


# ─── Redis HTML cache (Phase 2) ─────────────────────────────────────────────────
# Master switch. Checked as === 'true'. Leave 'false' until the cache is rolled
# out; when off, the plugin is a complete no-op (pure live render).
CACHE_ENABLED=false

# Preferred: full connection string. Use rediss:// for TLS (DO Managed Valkey).
# REDIS_URL=rediss://default:PASSWORD@HOST:PORT
# --- OR discrete settings (used only when REDIS_URL is unset) ---
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# Key namespace. Bump only via the in-code v1 schema version, not this.
# CACHE_KEY_PREFIX=prerender
# gzip the stored HTML body. Checked as !== 'false' (default on); set false to disable.
# CACHE_COMPRESSION=true
# Status-code policy:
#   200      cached, no TTL (refreshed by the cache-manager every 24h).
#   3xx      cached, no TTL (cache-manager refreshes every 7 days).
#   4xx      cached but auto-evicted after CACHE_4XX_TTL_MS, and the cache-manager
#            never schedules them for re-render (a recovered page heals on the next
#            live hit). 408/429 are OUR transient signals and are never cached.
#   5xx      never cached.
# Optional explicit allowlist; LEAVE UNSET to use the range policy above. Setting
# it pins an exact set instead, e.g. CACHE_CACHEABLE_STATUS=200,301,302,404.
# CACHE_CACHEABLE_STATUS=
# How long a cached 4xx body lives before it's auto-evicted (ms; default 24h).
# CACHE_4XX_TTL_MS=86400000
# Refuse to cache a 200 HTML body smaller than this many bytes — guards against
# permanently storing an empty/half-rendered shell. Applies to 200 only
# (3xx/404 legitimately have tiny/empty bodies). 0 = off.
# CACHE_MIN_HTML_BYTES=20000

# Per-domain stats memo TTL (ms) for GET /cache/stats/domains (the dashboard reads it).
# STATS_CACHE_TTL_MS=60000
# Namespaces the render/fallback metrics counters per deployment (e.g. ondemand /
# scheduled) so the seeder's renders don't mix with on-demand. Read by /cache/metrics.
# METRICS_LABEL=ondemand

# Where HTML bodies are stored: 'redis' (default; bodies in Valkey RAM) or
# 'spaces' (bodies in DO Spaces / S3 — far cheaper for a large no-eviction
# corpus; the single-flight lock + refresh index stay in Redis either way).
# Switching invalidates the existing cache (keys differ) — plan to re-seed.
# CACHE_STORE=spaces
# DO Spaces (or S3) settings — required when CACHE_STORE=spaces:
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_REGION=us-east-1
# SPACES_BUCKET=chicks-prerender-cache
# SPACES_PREFIX=                          # optional key prefix, e.g. prod/
# SPACES_KEY=                             # Spaces access key (or AWS_ACCESS_KEY_ID)
# SPACES_SECRET=                          # Spaces secret  (or AWS_SECRET_ACCESS_KEY)
# SPACES_FORCE_PATH_STYLE=false


# ─── In-server cache refresher ──────────────────────────────────────────────────
# Turns THIS instance into a self-driving cache refresher: whenever it has a free
# Chrome slot it re-renders the next stale cached entry (driven by the cache index
# + per-URL status, no sitemap). It does TIME-based refresh only; seeding new URLs
# and <lastmod>-driven refresh are the in-server sitemap seeder's job (next
# section), which runs alongside it on the same scheduled instances.
# ⚠ DEDICATED INSTANCES ONLY. Do NOT enable on the autoscaled on-demand tier:
#   refresh work keeps instances "busy" (blocks scale-down) and contends with live
#   crawler renders for the single vCPU. Set it true on the fixed scheduled box.
# REFRESHER_MODE=true
# Max concurrent refresh renders (defaults to MAX_CONCURRENT_RENDERS, else 4).
# REFRESHER_CONCURRENCY=4
# Re-render cached 2xx entries older than this (ms; default 24h).
# REFRESHER_REFRESH_TTL_MS=86400000
# Re-render cached 3xx entries older than this (ms; default 7d). 4xx are never
# refreshed (they auto-evict via CACHE_4XX_TTL_MS).
# REFRESHER_REDIRECT_TTL_MS=604800000
# How many index entries the time-based refresher may scan per tick while paging
# past — and reaping — expired ghost entries (e.g. 4xx whose body already TTL'd
# but whose index row lingers) to reach genuinely-due pages. Bounds the cost of a
# recovery pass when the oldest end of the index is clogged; raise it to drain a
# large ghost backlog faster. Default 5000.
# REFRESHER_MAX_SCAN=5000
# Loop pacing: how long to idle when nothing is due, and the top-up cadence while
# working (ms). Plus a per-render timeout (keep above PAGE_LOAD_TIMEOUT).
# REFRESHER_IDLE_INTERVAL_MS=60000
# REFRESHER_TICK_MS=1000
# REFRESHER_REQUEST_TIMEOUT_MS=75000
# After a refresh FAILS (render timeout / 5xx / transport error — NOT a 429/503
# backpressure shed) the URL is parked this long before it's eligible for a
# time-based refresh again, so a broken page (e.g. a prod route that times out)
# can't be re-selected every tick and crashloop while healthy due work starves.
# 0 disables the damper. (The work-queue path has its own attempt-based backoff.)
# REFRESHER_FAIL_COOLDOWN_MS=600000
# Cross-instance dedupe: when multiple scheduled boxes run, a per-URL refresh
# claim (SET NX PX) so two boxes don't render the same time-based refresh at once
# (the work queue already dedupes via ZPOPMIN). A FAILED refresh holds its claim
# for REFRESHER_FAIL_COOLDOWN_MS so no box retries a broken URL too soon; a success
# releases immediately. This is the claim TTL in ms — it must outlive the longest
# render, so it DEFAULTS to REFRESHER_REQUEST_TIMEOUT_MS + 60000 (and is floored
# above the request timeout). 0 disables dedupe (e.g. a single-instance tier).
# REFRESHER_CLAIM_TTL_MS=135000
# Over-fetch factor: ask dueForRefresh for this many × the free slots so a box can
# skip URLs another box already claimed and still fill its slots. Set it >= the
# number of scheduled instances so a busy cluster doesn't under-fill its slots.
# REFRESHER_CLAIM_OVERFETCH=3
# Prioritize re-caching due 2xx (content) pages over due 3xx/4xx so content stays
# fresh and redirects may go a bit stale under capacity pressure. Default on. NB:
# when on, a tick with 3xx work but no due 2xx scans up to REFRESHER_MAX_SCAN to
# confirm there's no 2xx to prefer (bounded; due 2xx can rank behind due 3xx). Set
# to 'false' for plain oldest-first (early-terminating) scans.
# REFRESHER_PRIORITIZE_2XX=true
# Background reaper: a dedicated sweep (separate timer) that evicts expired-by-policy
# entries — e.g. 4xx past their drop TTL — so they can't pile up faster than the
# lazy read/dueForRefresh reaps clear them (decoupled from render capacity). Runs
# only on REFRESHER_MODE instances; cluster-locked so one box sweeps at a time.
# Interval 0 disables. maxScan = how far down the oldest-first index to look per
# pass; maxEvict = max deletions per pass (bounds object-store DELETE load).
# REFRESHER_REAP_INTERVAL_MS=60000
# REFRESHER_REAP_MAX_SCAN=20000
# REFRESHER_REAP_MAX_EVICT=5000
# Reaper cluster-lock TTL (ms); a crashed sweeper frees the lock after this.
# REAPER_LOCK_TTL_MS=300000
# (Reuses PORT for the loopback call and PRERENDER_AUTH_TOKEN for its auth header.)
#
# Adaptive concurrency (recommended for the scheduled box): instead of a fixed
# REFRESHER_CONCURRENCY, auto-tune the number of concurrent refresh renders toward
# maximum throughput. It hill-climbs while throughput keeps improving, halves on any
# render failure (timeout / 5xx / Chrome-closed), and stays within
# [REFRESHER_MIN_CONCURRENCY, REFRESHER_CONCURRENCY]. MAX_CONCURRENT_RENDERS is still
# the absolute hard ceiling. NOTE: it is driven by throughput/failures, NOT CPU% (a
# CPU-bound render wants ~100% CPU); real cgroup CPU% is only logged for visibility.
# REFRESHER_ADAPTIVE=true
# REFRESHER_MIN_CONCURRENCY=1          # starting point + floor
# REFRESHER_ADAPT_INTERVAL_MS=10000    # how often to re-evaluate the limit
# REFRESHER_BACKOFF_FACTOR=0.5         # multiplier applied to the limit on failure
# REFRESHER_THROUGHPUT_MARGIN=0.1      # min fractional gain to keep climbing
# REFRESHER_VCPUS=                     # override vCPU count for the logged CPU% (else auto)
# A render slower than this (ms) counts as a backoff signal even if it returned
# 200 (a near-timeout render means the box is over-subscribed). Defaults to 80%
# of PAGE_LOAD_TIMEOUT. Pair with TIMEOUT_STATUS_CODE=504 so hard timeouts surface
# as failures rather than slow 200s.
# REFRESHER_SLOW_MS=
#
# The refresher consumes the Redis work queue that the in-server sitemap seeder
# produces (discover + enqueue, never render). A queued URL that fails is
# re-enqueued until it burns this many attempts, then dropped.
# CACHE_QUEUE_MAX_ATTEMPTS=3


# ─── In-server sitemap seeder (scheduled instances) ─────────────────────────────
# Runs automatically when REFRESHER_MODE=true AND CACHE_ENABLED=true (no flag of
# its own; replaces the external cache-manager worker). Periodically expands the
# ADMIN-MANAGED sitemap list — the dashboard "Sitemaps" page pushes it to
# POST /cache/sitemaps; there is NO env-based sitemap list, and an empty list
# means the seeder idles — and enqueues render work: uncached pages at priority
# 0, cached pages whose <lastmod> is newer than the cached copy at priority 1.
# Time-based refresh stays with the refresher above; 4xx pages are never
# re-enqueued (they auto-evict on their TTL, then reappear as new). Exactly one
# scan per interval runs cluster-wide (Redis lastScanAt gate + a renewed scan
# lock), so extra scheduled instances are safe.
# SEEDER_INTERVAL_MS=600000          # how often a scan is due (default 10 min)
# SEEDER_TICK_MS=60000               # how often each instance checks the gate
# SEEDER_FETCH_COOLDOWN_MS=1000      # pause between sitemap fetches (origin protection)
# SEEDER_LOCK_TTL_MS=120000          # scan-lock TTL; renewed after every fetch/batch
# SEEDER_FETCH_TIMEOUT_MS=30000      # per-sitemap fetch timeout
# SEEDER_MAX_DEPTH=4                 # sitemap-index recursion depth cap
# SEEDER_STATUS_BATCH=500            # URLs per cache-status diff / enqueue batch


# ─── Sitemap proxy ──────────────────────────────────────────────────────────────
# Serve Google-friendly sitemaps by proxying + rewriting the API's sitemap feed
# (replaces the standalone sitemap service). When enabled, two public routes are
# added (before the render catch-all, so no token/whitelist needed):
#   GET /sitemap_index.xml        -> fetch <API_BASE>/Sitemap/SitemapIndex?websiteShortCode=<code>
#                                    and rewrite child <loc>s to /sitemap/sitemap-<n>.xml
#   GET /sitemap/sitemap-<n>.xml  -> proxy the n-th child sitemap through, unchanged
# Fetch-and-rewrite only (no render), no caching (fresh each request). Enable on the
# tier that serves crawler traffic (on-demand) and point nginx /sitemap* at it.
# SITEMAP_PROXY_ENABLED=true
# SITEMAP_API_BASE=https://api.chicksgroup.com
# Per-environment API origins. The fork is shared across envs; nginx sends the
# X-Environment header (dev/staging/prod), and dev/staging then pull from these
# and rewrite the index to the dev./staging. host (e.g. dev.chicksx.com).
# SITEMAP_API_BASE_DEV=https://dev-api.chicksgroup.com
# SITEMAP_API_BASE_STAGING=https://staging-api.chicksgroup.com
# Host -> websiteShortCode map (apex hosts; www is stripped automatically).
# SITEMAP_SHORTCODES=chicksx.com:CX,chicksgold.com:CG
# SITEMAP_TIMEOUT_MS=15000
# Cache the upstream API sitemap fetches (index + each sub-sitemap) in Redis so
# the heavy DB-backed sitemap query runs at most once per TTL instead of on every
# crawler/cache-manager request. Single-flight (one regen at a time) + serve-stale
# on error. Needs REDIS_* configured; set TTL to 0 to disable (direct fetch).
# SITEMAP_CACHE_TTL_MS=21600000          # 6h fresh window
# SITEMAP_CACHE_STALE_TTL_MS=86400000    # keep an expired copy 24h for serve-stale
# SITEMAP_CACHE_WAIT_MS=15000            # cold-start waiter timeout before failing closed


# ─── SaaS fallback + cache-clear (prerender.io) ─────────────────────────────────
# FALLBACK: when our own render can't be served (capacity 429 / 5xx / timeout),
# proxy the request to the SaaS prerender, return that to the crawler, AND cache
# it (so the next request is a local hit). Requires an active prerender.io plan.
# FALLBACK_ENABLED=true
# FALLBACK_TOKEN=                          # prerender.io API token
# FALLBACK_URL=https://service.prerender.io
# FALLBACK_STATUS_CODES=429,500,502,503,504
# FALLBACK_TIMEOUT_MS=25000
# FALLBACK_FORCE=true                      # TEST ONLY: route EVERY request to the
#                                          # fallback (skips local render) to verify it
# Tip: also set TIMEOUT_STATUS_CODE=504 so render timeouts trigger the fallback.

# CACHE-CLEAR: after WE render a page fresh, evict prerender.io's now-stale copy
# so a later fallback re-renders fresh. Best-effort + serialized — the SaaS API
# allows only ONE clear job per account at a time, so under big render bursts the
# bounded queue drops overflow (pair with an occasional domain-pattern clear for
# guaranteed bulk freshness). Token defaults to FALLBACK_TOKEN/PRERENDER_IO_TOKEN.
# SAAS_CLEAR_ENABLED=true
# SAAS_CLEAR_TOKEN=
# SAAS_CLEAR_API=https://api.prerender.io
# SAAS_CLEAR_STATUS=200,301,302,404
# SAAS_CLEAR_MAX_QUEUE=5000

# Single-flight (stops a thundering herd of identical renders across instances).
# SINGLEFLIGHT_ENABLED=true          # checked as !== 'false'
# SINGLEFLIGHT_LOCK_TTL_MS=30000     # lock auto-expiry (must exceed worst-case render)
# SINGLEFLIGHT_WAIT_MAX_MS=5000      # max a waiter polls before rendering through
# SINGLEFLIGHT_WAIT_POLL_MS=150      # waiter poll interval


# ─── Optional plugins (NOT wired in server.js by default) ──────────────────────
# basicAuth — only if you swap it in for tokenAuth:
# BASIC_AUTH_USERNAME=
# BASIC_AUTH_PASSWORD=
# blacklist — only if you wire prerender.blacklist():
# BLACKLISTED_DOMAINS=
